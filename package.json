{
  "name": "mdefeo.github.io",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/mdefeo/mdefeo.github.io.git",
  "author": "Marcello De Feo <marcellodefeo@outlook.com>",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "start": "concurrently \"yarn workspace frontend start\" \"yarn workspace backend start\"",
    "start:frontend": "yarn workspace frontend start",
    "start:backend": "yarn workspace backend start",
    "test": "concurrently \"yarn workspace frontend test\" \"yarn workspace backend test\"",
    "test:frontend": "yarn workspace frontend test",
    "test:backend": "yarn workspace backend test",
    "test:watch": "yarn workspaces run test --watch",
    "lint": "eslint '*/**/*.{js,jsx,ts,tsx}' --fix"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^7.32.0",
    "prettier": "^2.3.2"
  }
}
